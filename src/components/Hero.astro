---
import orpheus from "../assets/flag-orpheus-left.svg?raw"
---

<div class="w-screen h-screen relative">
    <div class="absolute w-full h-3 bg-orange-400"></div>
    <div class="absolute w-full h-full bg-gray-950"></div>
    <div class = "absolute inset-0 flex flex-col items-center justify-center">
        <h1 class="font-display outline-gray-100 text-7xl sm:text-8xl md:text-9xl text-gray-100 [text-shadow:2px_2px_0_orange] md:[text-shadow:4px_4px_0_orange]">BOSSFIGHTING</h2>
        <h3 class="font-display fill-gray-600 text-lg text-gray-500 text-center px-10">YS: A bossfight in godot. WS: a game with everyone's bossfights (+cool merch! and other stuff)</h3>
        <div class = "flex-row m-5">
            <a class="
                p-2 px-3 rounded-full bg-orange-500 
                font-display text-lg text-orange-100 
                hover:bg-orange-400 hover:p-3 hover:px-4 ease-out duration-200
            " href="https://forms.fillout.com/t/kYJ6JdyEyQus">RSVP</a>
            <a class="
                p-2 px-3 rounded-full bg-orange-100
                font-display text-lg text-orange-500
                hover:bg-orange-200 hover:p-3 hover:px-4 ease-out duration-200
            " href="https://hackclub.enterprise.slack.com/archives/C09TG04FFK6">Join Slack</a>
        </div>
    </div>
    <a href="https://www.hackclub.com">
    <div class="absolute object-top-left my-5 w-40 origin-top-left hover:rotate-5 ease-out duration-300" >
        <Fragment set:html={orpheus} />
    </div>
    </a>
    
</div>