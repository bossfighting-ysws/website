---
import '../styles/global.css';
---
<section class="px-6 py-20 md:px-16 lg:px-24 max-w-3xl mx-auto ">
    
    <div class="reveal opacity-0 translate-y-20 transition-all duration-700 ease-out" data-reveal>
        <!-- tracking is letter spacing -->
        <p class="text-sm uppercase tracking-widest text-white/40 mb-2">
          <strong>boss /bôs/ </strong>
        </p>
        <p class="text-white/60 text-lg leading-relaxed"> A significantly powerful non-player character
          created as a major opponent to players.
        </p>
    </div>
</section>
<script>
const observer = new IntersectionObserver(
    (entries) => {
        entries.forEach((entry) => {
            // Once observed, change the class to revealed
            if (entry.isIntersecting) {
                entry.target.classList.add('opacity-100', 'translate-y-0');
                // Fire once
                observer.unobserve(entry.target);
            }
        })
    },
    // When 15% of any object enters the viewport, it is observed
    { threshold: 0.15, rootMargin: '0px 0px -100px 0px' }
);
document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>