---
import "../styles/global.css";
import Reveal from "../components/Reveal.astro";
const segmentsDefinition = [
    {
        words: ["Boss", "/bôs/"],
        class: "font-display text-5xl tracking-widest text-gray-100 [text-shadow:2px_2px_0_red] font-bold",
        holdAfter: 0.0,
        breakAfter: true,
    },
    {
        words: [
            "A",
            `<span class="bold decoration-solid text-red-500">significantly`,
            "powerful",
            "non-player",
            "character",
            "created",
            "as",
            "a",
            `<span class="text-red-500">major</span>`,
            `<span class="text-red-500">opponent</span>`,
            "to",
            "players.",
        ],
        class: "font-display text-white/60 text-3xl leading-7",
    },
];
const segmentsQuestion = [
    {
        words: ["Boss", "/bôs/"],
        class: "font-display text-5xl tracking-widest text-gray-100 [text-shadow:2px_2px_0_red] font-bold",
        // holdAfter: 0.0,
        // breakAfter: true,
    },
]
---

<section class="px-6 md:px-16 lg:px-24 max-w-3xl mx-auto">
    <Reveal segments={segmentsDefinition} scrollDuration=2 />
    <!-- <Reveal segments={segmentsQuestion} scrollDuration=2 /> -->
    <!-- <p class="font-display text-5xl outline-gray-10 [text-shadow:2px_2px_0_red] md:[text-shadow:4px_4px_0_red]">
        <strong>boss /bôs/ </strong>
    </p>
    <p class="font-display text-3xl text-white/60 leading-7">
        A significantly powerful non-player character created as a major
        opponent to players.
    </p> -->
</section>
