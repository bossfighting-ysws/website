---
interface Segment {
    words: string[];
    /// Pause before next segment (0-1) default is 0.07
    holdAfter?: number;
    /// How much scroll time this has; default = word count
    weight?: number;
}
interface Props {
    segments: Segment[];
    /// How many viewport-heights the reveal takes; default = 2.5
    scrollDuration?: number;
    class?: String;
    spanClass?: String;
}
const { segments, scrollDuration = 2.5, class: className = "", spanClass = "" } = Astro.props;

let wordIdx = 0;
const processed = segments.map((seg) => ({
    ...seg,
    holdAfter: seg.holdAfter ?? 0.07,
    weight: seg.weight ?? seg.words.length,
    startIdx: wordIdx,
    endIdx: (wordIdx += seg.words.length) - 1,
}));
---

<section
    class={`relative ${className}`}
    style={`height: calc(${scrollDuration} * 100vh + 200vh)`}
>
    <div class="sticky top-0 h-screen flex items-center justify-center px-6">
        <p
            class="reveal-text text-center leading-relaxed max-w-3xl text-lg text-white/90"
        >
            {
                processed.map((seg, si) => (
                    <>
                        {seg.words.map((word, wi) => (
                            <span
                                class={`word inline ${spanClass}`}
                                data-idx={seg.startIdx + wi}
                            >
                                {word}{" "}
                            </span>
                        ))}
                        {si < processed.length - 1 && <br />}
                    </>
                ))
            }
        </p>
    </div>
</section>
<script define:vars={{ processed, scrollDuration }}>
    const totalHold = processed.reduce((s, seg) => s + seg.holdAfter, 0);
    const activeRange = 1 - totalHold;
    const totalWeight = processed.reduce((s, seg) => s + seg.weight, 0);

    let cursor = 0;
    const segBounds = processed.map((seg) => {
        const rawActive = (seg.weight / totalWeight) * activeRange;
        const rawStart = cursor;
        const rawEnd = cursor + rawActive;
        cursor = rawEnd + seg.holdAfter;
        return { startIdx: seg.startIdx, endIdx: seg.endIdx, rawStart, rawEnd };
    });

    const words = document.querySelectorAll(".word[data-idx]");

    function wordOpacity(idx, wordPhase) {
        if (wordPhase === 0) return 0;
        const seg = segBounds.find((s) => idx >= s.startIdx && idx <= s.endIdx);
        if (!seg || wordPhase < seg.rawStart) return 0;

        const localPhase = Math.min(
            1,
            (wordPhase - seg.rawStart) / (seg.rawEnd - seg.rawStart),
        );
        const segSize = seg.endIdx - seg.startIdx + 1;
        const localIdx = idx - seg.startIdx;
        const fadeWindow = Math.min(1, 3 / segSize);
        const localStart = (localIdx / segSize) * (1 - fadeWindow);

        return Math.max(0, Math.min(1, (localPhase - localStart) / fadeWindow));
    }

    function update() {
        const vh = window.innerHeight;
        const section = document
            .querySelector(".reveal-text")
            ?.closest("section");
        if (!section) return;

        const wordPhase = Math.max(
            0,
            Math.min(
                1,
                (window.scrollY - section.offsetTop) / (vh * scrollDuration),
            ),
        );

        words.forEach((el) => {
            el.style.opacity = wordOpacity(parseInt(el.dataset.idx), wordPhase);
        });
    }

    window.addEventListener("scroll", update, { passive: true });
    update();
</script>
<style>
    .word {
        opacity: 0;
    }
</style>
